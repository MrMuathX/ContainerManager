# Copy to .env and adjust. Used by docker-compose `env_file`.

DASHBOARD_PASSWORD=change-me

# Home Assistant MQTT (optional)
MQTT_ENABLED=false
MQTT_HOST=homeassistant.local
MQTT_PORT=1883
MQTT_USER=
MQTT_PASSWORD=
MQTT_CLIENT_ID=containermanager
HA_DISCOVERY_PREFIX=homeassistant
STATS_INTERVAL=5

# Monitoring / outbound notifications (optional)
APP_URL=http://localhost:8081

# Auto-Update (Watchtower-style) — optional, configurable without the UI.
# These set DEFAULTS; settings saved from the UI (data/autoupdate_config.json)
# take precedence when present. Per-container opt-in also works via labels:
#   com.centurylinklabs.watchtower.enable=true|false
#   com.centurylinklabs.watchtower.monitor-only=true
AUTOUPDATE_ENABLED=false
AUTOUPDATE_INTERVAL=86400        # poll interval in seconds (default 24h)
AUTOUPDATE_SCOPE=opt-in          # opt-in (only flagged containers) or all
AUTOUPDATE_MONITOR_ONLY=false    # check & notify only, never apply
AUTOUPDATE_CLEANUP=true          # remove old images after a successful update
AUTOUPDATE_NOTIFY=true           # send notifications on update events
AUTOUPDATE_RESPECT_LABELS=true   # honor com.centurylinklabs.watchtower.* labels
